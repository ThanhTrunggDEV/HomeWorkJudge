<UserControl x:Class="HomeWorkJudge.UI.Views.RubricListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <DockPanel>
        <!-- ── Header ──────────────────────────────── -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Quản lý Rubric" Style="{StaticResource PageTitle}" DockPanel.Dock="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding ToggleAiPanelCommand}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AutoFix" VerticalAlignment="Center"/>
                        <TextBlock Text="AI Tạo" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateNewCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center"/>
                        <TextBlock Text="Tạo mới" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- ── AI Generation Panel (collapsible) ──── -->
        <Border DockPanel.Dock="Top" Style="{StaticResource ContentCard}"
                Visibility="{Binding ShowAiPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="🤖 AI tạo Rubric" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                <TextBox materialDesign:HintAssist.Hint="Tên Rubric (tuỳ chọn)"
                         Text="{Binding AiRubricName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,12"/>
                <TextBox materialDesign:HintAssist.Hint="Mô tả bài tập / yêu cầu (bắt buộc)"
                         Text="{Binding AiDescription, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                         Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding GenerateByAiCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Creation" VerticalAlignment="Center"/>
                            <TextBlock Text="Tạo bằng AI" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TextButton}" Content="Đóng"
                            Command="{Binding ToggleAiPanelCommand}" Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Search bar ──────────────────────────── -->
        <Border DockPanel.Dock="Top" Style="{StaticResource ContentCard}" Padding="12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding SearchCommand}" Margin="8,0,0,0">
                    <materialDesign:PackIcon Kind="Magnify"/>
                </Button>
                <TextBox materialDesign:HintAssist.Hint="Tìm kiếm rubric..."
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ── Loading indicator ───────────────────── -->
        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Margin="0,0,0,8"/>

        <!-- ── Rubric list ─────────────────────────── -->
        <Border Style="{StaticResource ContentCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Rubrics}"
                      SelectedItem="{Binding SelectedRubric}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HorizontalAlignment="Stretch">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Số tiêu chí" Binding="{Binding CriteriaCount}" Width="*"/>
                    <DataGridTextColumn Header="Tổng điểm tối đa" Binding="{Binding MaxTotalScore, StringFormat=F1}" Width="*"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="*"/>
                </DataGrid.Columns>
                <DataGrid.InputBindings>
                    <MouseBinding Gesture="LeftDoubleClick"
                                  Command="{Binding DataContext.EditRubricCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Chỉnh sửa" Command="{Binding EditRubricCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon><materialDesign:PackIcon Kind="Pencil"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Nhân bản" Command="{Binding CloneCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon><materialDesign:PackIcon Kind="ContentCopy"/></MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Xoá" Command="{Binding DeleteCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Foreground="#EF5350">
                            <MenuItem.Icon><materialDesign:PackIcon Kind="Delete" Foreground="#EF5350"/></MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- Error banner -->
        <Border DockPanel.Dock="Bottom" Background="#3AEF5350" CornerRadius="6" Padding="12,8" Margin="0,8,0,0"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}">
            <DockPanel>
                <materialDesign:PackIcon Kind="AlertCircle" DockPanel.Dock="Left" VerticalAlignment="Center"
                                         Foreground="#EF5350" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF5350"
                           TextWrapping="Wrap" VerticalAlignment="Center" FontSize="13"/>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
