<UserControl x:Class="HomeWorkJudge.UI.Views.SessionCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <Button Style="{StaticResource MaterialDesignIconButton}"
                    Command="{Binding GoBackCommand}" DockPanel.Dock="Left">
                <materialDesign:PackIcon Kind="ArrowLeft"/>
            </Button>
            <TextBlock Text="Tạo phiên chấm mới" Style="{StaticResource PageTitle}"
                       Margin="12,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                <!-- Session name -->
                <Border Style="{StaticResource ContentCard}">
                    <TextBox materialDesign:HintAssist.Hint="Tên phiên chấm (VD: Bài 1 - Lớp CS101)"
                             Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             FontSize="16"/>
                </Border>

                <!-- Select rubric -->
                <Border Style="{StaticResource ContentCard}">
                    <ComboBox materialDesign:HintAssist.Hint="Chọn Rubric"
                              ItemsSource="{Binding Rubrics}"
                              SelectedItem="{Binding SelectedRubric}"
                              DisplayMemberPath="Name"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>
                </Border>

                <!-- Select files -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding SelectFilesCommand}"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderOpen" VerticalAlignment="Center"/>
                                <TextBlock Text="Chọn file bài nộp (zip/rar)" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <ItemsControl ItemsSource="{Binding SelectedFiles}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource CaptionText}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Create button -->
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding CreateSessionCommand}"
                        Content="Tạo phiên chấm"
                        Padding="32,12" HorizontalAlignment="Left"
                        Margin="0,8,0,0"/>

                <!-- Result message -->
                <TextBlock Text="{Binding ResultMessage}" FontSize="14"
                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                           Margin="0,16,0,0"
                           Visibility="{Binding ResultMessage, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
