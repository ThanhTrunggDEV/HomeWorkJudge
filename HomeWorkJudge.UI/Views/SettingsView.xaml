<UserControl x:Class="HomeWorkJudge.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="Cài đặt AI" Style="{StaticResource PageTitle}"/>

            <Border Style="{StaticResource ContentCard}">
                <StackPanel>
                    <TextBlock Text="Gemini API" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>

                    <TextBox materialDesign:HintAssist.Hint="API Key"
                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,16"/>

                    <TextBox materialDesign:HintAssist.Hint="Model"
                             Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding Temperature, StringFormat='Temperature: {0:F2}'}" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="1" TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding Temperature}"
                            Style="{StaticResource MaterialDesignDiscreteSlider}"
                            Margin="0,0,0,16"/>

                    <TextBox materialDesign:HintAssist.Hint="Timeout (giây)"
                             Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,16"/>
                </StackPanel>
            </Border>

            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveCommand}"
                    Content="Lưu cấu hình" Padding="32,12" Margin="0,8,0,0"
                    HorizontalAlignment="Left"/>

            <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
