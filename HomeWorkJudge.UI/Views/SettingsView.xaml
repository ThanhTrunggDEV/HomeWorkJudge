<UserControl x:Class="HomeWorkJudge.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="Cài đặt" Style="{StaticResource PageTitle}"/>

            <!-- ── Giao diện ──────────────────────────── -->
            <Border Style="{StaticResource ContentCard}">
                <StackPanel>
                    <TextBlock Text="Giao diện" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>

                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Width="22" Height="22"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Dark Mode" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                        <ToggleButton DockPanel.Dock="Right" HorizontalAlignment="Right"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="{Binding IsDarkMode}"/>
                    </DockPanel>
                    <TextBlock Text="Chuyển đổi giao diện sáng / tối (áp dụng ngay)"
                               Style="{StaticResource CaptionText}" Margin="32,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Gemini API ─────────────────────────── -->
            <Border Style="{StaticResource ContentCard}">
                <StackPanel>
                    <TextBlock Text="Gemini API" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>

                    <TextBox materialDesign:HintAssist.Hint="API Key"
                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,16"/>

                    <TextBox materialDesign:HintAssist.Hint="Model"
                             Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding Temperature, StringFormat='Temperature: {0:F2}'}" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="1" TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding Temperature}"
                            Style="{StaticResource MaterialDesignDiscreteSlider}"
                            Margin="0,0,0,16"/>

                    <TextBox materialDesign:HintAssist.Hint="Timeout (giây)"
                             Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,16"/>
                </StackPanel>
            </Border>

            <!-- Save -->
            <Button Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    Margin="0,8,0,0" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Width="18" Height="18"/>
                    <TextBlock Text="Lưu cấu hình" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
