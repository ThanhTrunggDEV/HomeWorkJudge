<UserControl x:Class="HomeWorkJudge.UI.Views.RubricEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <Button Style="{StaticResource MaterialDesignIconButton}"
                    Command="{Binding GoBackCommand}" DockPanel.Dock="Left">
                <materialDesign:PackIcon Kind="ArrowLeft"/>
            </Button>
            <TextBlock Text="{Binding RubricName, StringFormat='Rubric: {0}', FallbackValue='Rubric mới'}"
                       Style="{StaticResource PageTitle}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            <Button Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center"/>
                    <TextBlock Text="Lưu Rubric" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </DockPanel>

        <!-- Rubric name -->
        <Border DockPanel.Dock="Top" Style="{StaticResource ContentCard}">
            <TextBox materialDesign:HintAssist.Hint="Tên Rubric"
                     Text="{Binding RubricName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     FontSize="16"/>
        </Border>

        <!-- Add / Edit criteria form -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource ContentCard}">
            <StackPanel>
                <!-- Title: Thêm / Sửa -->
                <TextBlock Text="Thêm tiêu chí" Style="{StaticResource SectionTitle}"
                           Visibility="{Binding IsEditingCriteria, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                <TextBlock Text="✏️ Sửa tiêu chí (chọn hàng bên dưới)" Style="{StaticResource SectionTitle}"
                           Visibility="{Binding IsEditingCriteria, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Input fields -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Tên"
                             Text="{Binding FormCriteriaName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    <TextBox Grid.Column="1" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Điểm tối đa"
                             Text="{Binding FormCriteriaMaxScore, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    <TextBox Grid.Column="2"
                             materialDesign:HintAssist.Hint="Mô tả"
                             Text="{Binding FormCriteriaDescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                </Grid>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Right">
                    <!-- ADD mode -->
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCriteriaCommand}"
                            Visibility="{Binding IsEditingCriteria, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center"/>
                            <TextBlock Text="Thêm" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- EDIT mode -->
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding UpdateCriteriaCommand}"
                            Visibility="{Binding IsEditingCriteria, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Check" VerticalAlignment="Center"/>
                            <TextBlock Text="Cập nhật" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DangerButton}"
                            Command="{Binding RemoveCriteriaCommand}" Margin="8,0,0,0"
                            Visibility="{Binding IsEditingCriteria, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" VerticalAlignment="Center"/>
                            <TextBlock Text="Xoá" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource TextButton}"
                            Command="{Binding CancelEditCommand}" Margin="8,0,0,0"
                            Content="Huỷ"
                            Visibility="{Binding IsEditingCriteria, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Criteria table -->
        <Border Style="{StaticResource ContentCard}">
            <DataGrid ItemsSource="{Binding Criteria}"
                      SelectedItem="{Binding SelectedCriteria}"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên tiêu chí" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Điểm tối đa" Binding="{Binding MaxScore, StringFormat=F1}" Width="100"/>
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Error banner -->
        <Border DockPanel.Dock="Bottom" Background="#3AEF5350" CornerRadius="6" Padding="12,8" Margin="0,8,0,0"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}">
            <DockPanel>
                <materialDesign:PackIcon Kind="AlertCircle" DockPanel.Dock="Left" VerticalAlignment="Center"
                                         Foreground="#EF5350" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF5350"
                           TextWrapping="Wrap" VerticalAlignment="Center" FontSize="13"/>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
