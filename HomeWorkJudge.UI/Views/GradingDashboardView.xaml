<UserControl x:Class="HomeWorkJudge.UI.Views.GradingDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:HomeWorkJudge.UI.Converters">
    <UserControl.Resources>
        <converters:StatusToBrushConverter x:Key="StatusBrush"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button Style="{StaticResource MaterialDesignIconButton}"
                    Command="{Binding GoBackCommand}" DockPanel.Dock="Left">
                <materialDesign:PackIcon Kind="ArrowLeft"/>
            </Button>
            <TextBlock Text="{Binding SessionName}" Style="{StaticResource PageTitle}"
                       Margin="12,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Statistics cards -->
        <UniformGrid DockPanel.Dock="Top" Rows="1" Margin="0,0,0,12">
            <Border Style="{StaticResource ContentCard}" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Statistics.TotalCount, FallbackValue=0}"
                               FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Tổng bài nộp" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ContentCard}" Margin="4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Statistics.AIGradedCount, FallbackValue=0}"
                               FontSize="28" FontWeight="Bold" Foreground="{StaticResource StatusAIGradedBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="AI đã chấm" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ContentCard}" Margin="4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Statistics.ReviewedCount, FallbackValue=0}"
                               FontSize="28" FontWeight="Bold" Foreground="{StaticResource StatusReviewedBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Đã duyệt" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ContentCard}" Margin="4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Statistics.AverageScore, StringFormat=F2, FallbackValue=--}"
                               FontSize="28" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Điểm TB" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ContentCard}" Margin="8,0,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Statistics.ErrorCount, FallbackValue=0}"
                               FontSize="28" FontWeight="Bold" Foreground="{StaticResource StatusErrorBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Lỗi" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Action buttons -->
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding StartGradingCommand}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="RobotOutline" VerticalAlignment="Center"/>
                    <TextBlock Text="Chấm AI" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding RegradeAllCommand}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center"/>
                    <TextBlock Text="Chấm lại" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding CheckPlagiarismCommand}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentCopy" VerticalAlignment="Center"/>
                    <TextBlock Text="Kiểm tra đạo văn" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding ExportCsvCommand}" Margin="0,0,4,0" Content="CSV"/>
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding ExportExcelCommand}" Content="Excel"/>
        </WrapPanel>

        <!-- Status message -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,8"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}"/>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Margin="0,0,0,8"/>

        <!-- Submission DataGrid -->
        <DataGrid ItemsSource="{Binding Submissions}"
                  SelectedItem="{Binding SelectedSubmission}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick"
                              Command="{Binding OpenSubmissionCommand}"
                              CommandParameter="{Binding SelectedSubmission}"/>
            </DataGrid.InputBindings>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Mở" Command="{Binding OpenSubmissionCommand}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        <MenuItem.Icon><materialDesign:PackIcon Kind="OpenInApp"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Chấm lại" Command="{Binding RegradeOneCommand}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        <MenuItem.Icon><materialDesign:PackIcon Kind="Refresh"/></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sinh viên" Binding="{Binding StudentIdentifier}" Width="*"/>
                <DataGridTemplateColumn Header="Trạng thái" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                                    CornerRadius="10" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="White"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Điểm" Binding="{Binding TotalScore, StringFormat=F2}" Width="80"/>
                <DataGridTemplateColumn Header="Đạo văn" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <materialDesign:PackIcon Kind="AlertCircle"
                                                     Foreground="{StaticResource StatusErrorBrush}"
                                                     Visibility="{Binding IsPlagiarismSuspected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Ngày import" Binding="{Binding ImportedAt, StringFormat=dd/MM HH:mm}" Width="120"/>
                <!-- Chấm lại nhanh từ dashboard -->
                <DataGridTemplateColumn Header="" Width="36">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Width="28" Height="28"
                                    Command="{Binding DataContext.RegradeOneCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Chấm lại bài này">
                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
