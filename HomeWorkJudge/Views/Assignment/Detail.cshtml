@model AssignmentDetailPageViewModel
@{
    ViewData["Title"] = "Assignment Detail";
}

<h2>Assignment Detail</h2>

@if (Model.Assignment is null)
{
    <div class="alert alert-warning">Assignment not found.</div>
}
else
{
    <div class="d-flex gap-2 mb-3">
        <a asp-controller="Submission" asp-action="Create" asp-route-assignmentId="@Model.Assignment.AssignmentId" class="btn btn-primary">Submit Code</a>
        @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-assignmentId="@Model.Assignment.AssignmentId" class="btn btn-outline-secondary">Edit</a>
        }
        <a asp-action="Index" asp-route-classroomId="@Model.Assignment.ClassroomId" class="btn btn-link">Back to list</a>
    </div>

    <dl class="row">
        <dt class="col-sm-3">AssignmentId</dt>
        <dd class="col-sm-9">@Model.Assignment.AssignmentId</dd>

        <dt class="col-sm-3">ClassroomId</dt>
        <dd class="col-sm-9">@Model.Assignment.ClassroomId</dd>

        <dt class="col-sm-3">Title</dt>
        <dd class="col-sm-9">@Model.Assignment.Title</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9" style="white-space: pre-wrap">@Model.Assignment.Description</dd>

        <dt class="col-sm-3">Allowed Languages</dt>
        <dd class="col-sm-9">@string.Join(", ", Model.Assignment.AllowedLanguages)</dd>

        <dt class="col-sm-3">Due Date</dt>
        <dd class="col-sm-9">@Model.Assignment.DueDate.ToString("u")</dd>

        <dt class="col-sm-3">Publish Status</dt>
        <dd class="col-sm-9">@Model.Assignment.PublishStatus</dd>

        <dt class="col-sm-3">Grading Type</dt>
        <dd class="col-sm-9">@Model.Assignment.GradingType</dd>

        <dt class="col-sm-3">Time Limit (ms)</dt>
        <dd class="col-sm-9">@Model.Assignment.TimeLimitMs</dd>

        <dt class="col-sm-3">Memory Limit (KB)</dt>
        <dd class="col-sm-9">@Model.Assignment.MemoryLimitKb</dd>

        <dt class="col-sm-3">Max Submissions</dt>
        <dd class="col-sm-9">@Model.Assignment.MaxSubmissions</dd>
    </dl>

    @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
    {
        @if (Model.Assignment.GradingType == Ports.DTO.Common.AssignmentGradingTypeDto.TestCase)
        {
            <hr />
            <h4>Manage Test Cases</h4>

            @if (Model.Assignment.TestCases.Count == 0)
            {
                <p class="text-muted">No test cases configured.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>TestCaseId</th>
                                <th>Input</th>
                                <th>Expected</th>
                                <th>Hidden</th>
                                <th>Weight</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var testCase in Model.Assignment.TestCases)
                            {
                                <tr>
                                    <td class="font-monospace">@testCase.TestCaseId</td>
                                    <td>@testCase.InputData</td>
                                    <td>@testCase.ExpectedOutput</td>
                                    <td>@testCase.IsHidden</td>
                                    <td>@testCase.ScoreWeight</td>
                                    <td>
                                        <form asp-action="DeleteTestCase" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="AssignmentId" value="@Model.Assignment.AssignmentId" />
                                            <input type="hidden" name="TestCaseId" value="@testCase.TestCaseId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="6">
                                        <form asp-action="UpdateTestCase" method="post" class="row g-2 align-items-end">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="AssignmentId" value="@Model.Assignment.AssignmentId" />
                                            <input type="hidden" name="TestCaseId" value="@testCase.TestCaseId" />

                                            <div class="col-md-3">
                                                <label class="form-label">Input</label>
                                                <input name="InputData" value="@testCase.InputData" class="form-control" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label">Expected Output</label>
                                                <input name="ExpectedOutput" value="@testCase.ExpectedOutput" class="form-control" />
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label">Score Weight</label>
                                                <input name="ScoreWeight" value="@testCase.ScoreWeight" class="form-control" />
                                            </div>
                                            <div class="col-md-2 form-check pt-4">
                                                <input type="checkbox" name="IsHidden" value="true" class="form-check-input" @(testCase.IsHidden ? "checked" : null) />
                                                <label class="form-check-label">Hidden</label>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                                            </div>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="card mt-3">
                <div class="card-header">Add Test Case</div>
                <div class="card-body">
                    <form asp-action="AddTestCase" method="post" class="row g-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="AssignmentId" value="@Model.Assignment.AssignmentId" />

                        <div class="col-md-4">
                            <label class="form-label">Input</label>
                            <input name="InputData" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Expected Output</label>
                            <input name="ExpectedOutput" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Score Weight</label>
                            <input name="ScoreWeight" value="1" class="form-control" />
                        </div>
                        <div class="col-md-2 form-check pt-4">
                            <input type="checkbox" name="IsHidden" value="true" class="form-check-input" />
                            <label class="form-check-label">Hidden</label>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">Add Test Case</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else if (Model.Assignment.GradingType == Ports.DTO.Common.AssignmentGradingTypeDto.Rubric)
        {
            <hr />
            <h4>Manage Rubric</h4>

            @if (Model.Assignment.RubricCriteria.Count == 0)
            {
                <p class="text-muted">No rubric criteria configured.</p>
            }
            else
            {
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Weight</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Assignment.RubricCriteria)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Description</td>
                                <td>@item.Weight</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <div class="card mt-3">
                <div class="card-header">Upsert Rubric Criteria</div>
                <div class="card-body">
                    <form asp-action="SaveRubric" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="AssignmentId" value="@Model.Assignment.AssignmentId" />
                        <div class="mb-2">
                            <label class="form-label">Criteria Lines (Name|Description|Weight)</label>
                            <textarea name="CriteriaText" rows="8" class="form-control">@Model.RubricForm.CriteriaText</textarea>
                            <span class="form-text">One criteria per line. Example: Correctness|Produces expected output|40</span>
                        </div>
                        <button type="submit" class="btn btn-primary">Save Rubric</button>
                    </form>
                </div>
            </div>
        }
    }
}
