@model CreateAssignmentViewModel
@{
    ViewData["Title"] = "Create Assignment";
}

<h2>Create Assignment</h2>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="ClassroomId" class="form-label"></label>
        <input asp-for="ClassroomId" class="form-control" />
        <span asp-validation-for="ClassroomId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" rows="4" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="AllowedLanguagesCsv" class="form-label"></label>
        <input asp-for="AllowedLanguagesCsv" class="form-control" />
        <span class="form-text">Comma-separated, example: csharp,python</span>
    </div>

    <div class="col-md-6">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" type="datetime-local" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="GradingType" class="form-label"></label>
        <select asp-for="GradingType" asp-items="Html.GetEnumSelectList<Ports.DTO.Common.AssignmentGradingTypeDto>()" class="form-select"></select>
    </div>

    <div class="col-md-4">
        <label asp-for="TimeLimitMs" class="form-label"></label>
        <input asp-for="TimeLimitMs" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="MemoryLimitKb" class="form-label"></label>
        <input asp-for="MemoryLimitKb" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="MaxSubmissions" class="form-label"></label>
        <input asp-for="MaxSubmissions" class="form-control" />
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" asp-route-classroomId="@Model.ClassroomId" class="btn btn-link">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
