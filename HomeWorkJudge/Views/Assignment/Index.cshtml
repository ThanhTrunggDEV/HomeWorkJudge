@model AssignmentListPageViewModel
@{
    ViewData["Title"] = "Assignments";
}

<h2>Assignments</h2>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <label class="form-label">Classroom ID</label>
        <input name="classroomId" value="@Model.ClassroomId" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Page</label>
        <input name="pageNumber" value="@(Model.PageNumber <= 0 ? 1 : Model.PageNumber)" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Page Size</label>
        <input name="pageSize" value="@(Model.PageSize <= 0 ? 20 : Model.PageSize)" class="form-control" />
    </div>
    <div class="col-md-4 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Load</button>
        @if (Model.ClassroomId != Guid.Empty && (User.IsInRole("Teacher") || User.IsInRole("Admin")))
        {
            <a asp-action="Create" asp-route-classroomId="@Model.ClassroomId" class="btn btn-outline-primary">Create Assignment</a>
        }
    </div>
</form>

@if (Model.Items.Count == 0)
{
    <p class="text-muted">No assignments loaded.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Assignment ID</th>
                <th>Title</th>
                <th>Due Date</th>
                <th>Grading</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.AssignmentId</td>
                <td>@item.Title</td>
                <td>@item.DueDate.ToString("u")</td>
                <td>@item.GradingType</td>
                <td>@item.PublishStatus</td>
                <td class="d-flex gap-2">
                    <a asp-action="Detail" asp-route-assignmentId="@item.AssignmentId" class="btn btn-sm btn-outline-primary">Detail</a>
                    <a asp-controller="Submission" asp-action="Create" asp-route-assignmentId="@item.AssignmentId" class="btn btn-sm btn-outline-success">Submit</a>
                    @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-assignmentId="@item.AssignmentId" class="btn btn-sm btn-outline-secondary">Edit</a>
                    }
                    @if ((User.IsInRole("Teacher") || User.IsInRole("Admin")) && item.PublishStatus == Ports.DTO.Common.AssignmentPublishStatusDto.Draft)
                    {
                        <form asp-action="Publish" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="AssignmentId" value="@item.AssignmentId" />
                            <input type="hidden" name="ClassroomId" value="@Model.ClassroomId" />
                            <button type="submit" class="btn btn-sm btn-warning">Publish</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
