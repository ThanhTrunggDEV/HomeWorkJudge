@model EditAssignmentViewModel
@{
    ViewData["Title"] = "Edit Assignment";
}

<h2>Edit Assignment</h2>

<form asp-action="Edit" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input asp-for="AssignmentId" type="hidden" />
    <input asp-for="ClassroomId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label class="form-label">AssignmentId</label>
        <input value="@Model.AssignmentId" class="form-control" readonly />
    </div>

    <div class="col-md-6">
        <label class="form-label">ClassroomId</label>
        <input value="@Model.ClassroomId" class="form-control" readonly />
    </div>

    <div class="col-md-6">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" rows="4" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="AllowedLanguagesCsv" class="form-label"></label>
        <input asp-for="AllowedLanguagesCsv" class="form-control" />
    </div>

    <div class="col-md-6">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" type="datetime-local" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="TimeLimitMs" class="form-label"></label>
        <input asp-for="TimeLimitMs" class="form-control" />
        <span asp-validation-for="TimeLimitMs" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="MemoryLimitKb" class="form-label"></label>
        <input asp-for="MemoryLimitKb" class="form-control" />
        <span asp-validation-for="MemoryLimitKb" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="MaxSubmissions" class="form-label"></label>
        <input asp-for="MaxSubmissions" class="form-control" />
        <span asp-validation-for="MaxSubmissions" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Detail" asp-route-assignmentId="@Model.AssignmentId" class="btn btn-link">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
