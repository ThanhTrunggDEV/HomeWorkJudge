@model ScoreboardViewModel
@{
    ViewData["Title"] = "Scoreboard";
}

<h2>Scoreboard</h2>

<form asp-action="Scoreboard" method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <label class="form-label">Classroom ID</label>
        <input name="classroomId" value="@Model.ClassroomId" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Assignment ID (optional)</label>
        <input name="assignmentId" value="@(Model.AssignmentId?.ToString() ?? string.Empty)" class="form-control" />
    </div>
    <div class="col-md-3 d-flex align-items-end gap-2">
        <button class="btn btn-primary" type="submit">Load Scoreboard</button>
        @if (Model.ClassroomId != Guid.Empty && (User.IsInRole("Teacher") || User.IsInRole("Admin")))
        {
            <a asp-action="Export" asp-route-classroomId="@Model.ClassroomId" asp-route-assignmentId="@Model.AssignmentId" asp-route-format="csv" class="btn btn-outline-success">Export CSV</a>
        }
    </div>
</form>

@if (Model.Items.Count == 0)
{
    <p class="text-muted">No scoreboard data.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Student ID</th>
                <th>Name</th>
                <th>Average Score</th>
                <th>Submission Count</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.StudentId</td>
                <td>@item.StudentName</td>
                <td>@item.AverageScore</td>
                <td>@item.SubmissionCount</td>
            </tr>
        }
        </tbody>
    </table>
}
