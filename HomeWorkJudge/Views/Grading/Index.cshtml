@model GradingPanelViewModel
@{
    ViewData["Title"] = "Grading Panel";
    var detail = ViewData["SubmissionDetail"] as Ports.DTO.Submission.SubmissionDetailDto;
}

<h2>Grading Panel</h2>

@if (detail is not null)
{
    <div class="alert alert-secondary">
        Submission: <strong>@detail.SubmissionId</strong>, Status: <strong>@detail.Status</strong>, TotalScore: <strong>@detail.TotalScore</strong>
    </div>
}

<div class="d-flex flex-wrap gap-2 mb-3">
    <form asp-action="GradeTestCase" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SubmissionId" />
        <button type="submit" class="btn btn-warning">Grade By Test Case</button>
    </form>

    <form asp-action="GradeRubric" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SubmissionId" />
        <button type="submit" class="btn btn-warning">Grade By Rubric</button>
    </form>
</div>

<div class="card">
    <div class="card-header">Override Total Score</div>
    <div class="card-body">
        <form asp-action="OverrideScore" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SubmissionId" />

            <div class="col-md-4">
                <label asp-for="NewTotalScore" class="form-label"></label>
                <input asp-for="NewTotalScore" class="form-control" />
                <span asp-validation-for="NewTotalScore" class="text-danger"></span>
            </div>

            <div class="col-md-8">
                <label asp-for="OverrideReason" class="form-label"></label>
                <input asp-for="OverrideReason" class="form-control" />
                <span asp-validation-for="OverrideReason" class="text-danger"></span>
            </div>

            <div class="col-12">
                <button class="btn btn-danger" type="submit">Override Score</button>
            </div>
        </form>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">Review AI Rubric Result</div>
    <div class="card-body">
        <form asp-action="ReviewRubric" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SubmissionId" />

            <div class="col-md-4">
                <label class="form-label">Decision</label>
                <select asp-for="IsApproved" class="form-select">
                    <option value="true">Approve</option>
                    <option value="false">Reject and Queue Retry</option>
                </select>
            </div>

            <div class="col-md-8">
                <label asp-for="TeacherComment" class="form-label"></label>
                <input asp-for="TeacherComment" class="form-control" />
                <span class="form-text">Required when decision is Reject.</span>
            </div>

            <div class="col-12">
                <button class="btn btn-outline-primary" type="submit">Submit Review Decision</button>
            </div>
        </form>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">Override Rubric Criteria Score</div>
    <div class="card-body">
        <form asp-action="OverrideRubricCriteria" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SubmissionId" />

            <div class="col-md-4">
                <label asp-for="CriteriaName" class="form-label"></label>
                <input asp-for="CriteriaName" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="NewCriteriaScore" class="form-label"></label>
                <input asp-for="NewCriteriaScore" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="CriteriaOverrideReason" class="form-label"></label>
                <input asp-for="CriteriaOverrideReason" class="form-control" />
            </div>

            <div class="col-12">
                <button class="btn btn-outline-danger" type="submit">Override Criteria Score</button>
            </div>
        </form>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">Explain Rubric Deduction</div>
    <div class="card-body">
        <form asp-action="ExplainRubric" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SubmissionId" />

            <div class="col-md-4">
                <label asp-for="CriteriaName" class="form-label"></label>
                <input asp-for="CriteriaName" class="form-control" />
            </div>

            <div class="col-md-8">
                <label asp-for="StudentQuestion" class="form-label"></label>
                <input asp-for="StudentQuestion" class="form-control" placeholder="Why did this criteria lose points?" />
            </div>

            <div class="col-12">
                <button class="btn btn-outline-secondary" type="submit">Generate Explanation</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
