@model SubmissionHistoryViewModel
@{
    ViewData["Title"] = "Submission History";
}

<h2>Submission History</h2>

@if (Model.Page is null || Model.Page.Items.Count == 0)
{
    <p class="text-muted">No submissions available.</p>
}
else
{
    var totalPages = (int)Math.Ceiling((double)Model.Page.TotalCount / Model.Page.PageSize);
    var hasPrevious = Model.Page.PageNumber > 1;
    var hasNext = Model.Page.PageNumber < totalPages;

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Submission ID</th>
                <th>Assignment ID</th>
                <th>Status</th>
                <th>Total Score</th>
                <th>Submitted At</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Page.Items)
        {
            <tr>
                <td>@item.SubmissionId</td>
                <td>@item.AssignmentId</td>
                <td>@item.Status</td>
                <td>@item.TotalScore</td>
                <td>@item.SubmittedAt.ToString("u")</td>
                <td>
                    <a asp-action="Detail" asp-route-submissionId="@item.SubmissionId" class="btn btn-sm btn-outline-primary">Detail</a>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center">
        <span class="text-muted">
            Page @Model.Page.PageNumber / @totalPages, total @Model.Page.TotalCount submissions
        </span>
        <div class="btn-group">
            <a asp-action="History"
               asp-route-pageNumber="@(hasPrevious ? Model.Page.PageNumber - 1 : 1)"
               asp-route-pageSize="@Model.Page.PageSize"
               class="btn btn-outline-secondary @(hasPrevious ? "" : "disabled")">
                Previous
            </a>
            <a asp-action="History"
               asp-route-pageNumber="@(hasNext ? Model.Page.PageNumber + 1 : Model.Page.PageNumber)"
               asp-route-pageSize="@Model.Page.PageSize"
               class="btn btn-outline-secondary @(hasNext ? "" : "disabled")">
                Next
            </a>
        </div>
    </div>
}
