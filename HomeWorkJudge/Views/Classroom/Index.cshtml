@model ClassroomIndexViewModel
@{
    ViewData["Title"] = "Classroom";
}

<h2>Classroom</h2>

@if (Model.LastClassroomId.HasValue)
{
    <div class="alert alert-secondary">
        Last classroom id: <strong>@Model.LastClassroomId</strong>
        @if (!string.IsNullOrWhiteSpace(Model.LastJoinCode))
        {
            <span>, join code: <strong>@Model.LastJoinCode</strong></span>
        }
    </div>
}

@if (Model.Overview is not null)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Classroom Overview</span>
            <span class="badge text-bg-secondary">@Model.Overview.ClassroomId</span>
        </div>
        <div class="card-body">
            <dl class="row mb-3">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Overview.Name</dd>

                <dt class="col-sm-3">Join Code</dt>
                <dd class="col-sm-9"><span class="badge text-bg-info">@Model.Overview.JoinCode</span></dd>

                <dt class="col-sm-3">Teacher</dt>
                <dd class="col-sm-9">@Model.Overview.TeacherName (@Model.Overview.TeacherId)</dd>

                <dt class="col-sm-3">Students</dt>
                <dd class="col-sm-9">@Model.Overview.StudentCount</dd>
            </dl>

            <h5>Members</h5>
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>UserId</th>
                        <th>Full Name</th>
                        <th>Role</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model.Overview.Members)
                    {
                        <tr>
                            <td>@member.UserId</td>
                            <td>@member.FullName</td>
                            <td>@member.Role</td>
                        </tr>
                    }
                </tbody>
            </table>

            <h5>Assignments</h5>
            @if (Model.Overview.Assignments.Count == 0)
            {
                <p class="text-muted">No assignments yet.</p>
            }
            else
            {
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Due Date</th>
                            <th>Publish</th>
                            <th>Grading</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var assignment in Model.Overview.Assignments)
                        {
                            <tr>
                                <td>@assignment.Title</td>
                                <td>@assignment.DueDate.ToString("u")</td>
                                <td>@assignment.PublishStatus</td>
                                <td>@assignment.GradingType</td>
                                <td>
                                    <a asp-controller="Assignment" asp-action="Detail" asp-route-assignmentId="@assignment.AssignmentId" class="btn btn-sm btn-outline-primary">Detail</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Create Classroom (Teacher/Admin)</div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="CreateForm.Name" class="form-label"></label>
                        <input asp-for="CreateForm.Name" class="form-control" />
                        <span asp-validation-for="CreateForm.Name" class="text-danger"></span>
                    </div>
                    <button class="btn btn-primary" type="submit">Create</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Join Classroom (Student)</div>
            <div class="card-body">
                <form asp-action="Join" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="JoinForm.JoinCode" class="form-label"></label>
                        <input asp-for="JoinForm.JoinCode" class="form-control" />
                        <span asp-validation-for="JoinForm.JoinCode" class="text-danger"></span>
                    </div>
                    <button class="btn btn-success" type="submit">Join</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
