@model ErrorViewModel
@{
    ViewData["Title"] = $"Error {Model.StatusCode}";
}

<div class="py-4">
    <h1 class="text-danger">Error @Model.StatusCode</h1>
    <p class="lead">@Model.FriendlyMessage</p>

    <div class="d-flex gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Dashboard</a>
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-primary">Go to Login</a>
        }
    </div>

    @if (Model.ShowRequestId)
    {
        <p class="mt-3 mb-0 text-muted">Request ID: @Model.RequestId</p>
    }
</div>
