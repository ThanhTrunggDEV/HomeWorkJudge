@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<h2>Profile</h2>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">User ID</dt>
            <dd class="col-sm-9">@Model.UserId</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Role</dt>
            <dd class="col-sm-9">@Model.Role</dd>

            <dt class="col-sm-3">Session Expires</dt>
            <dd class="col-sm-9">@(Model.SessionExpiresAt?.ToString("u") ?? "n/a")</dd>
        </dl>
    </div>
</div>
